# Cloud LLM Configuration
# Provider: gemini, anthropic, openai
LLM_SERVICE=gemini
# Model identifier (examples: gemini-3.1-flash-lite-preview, claude-sonnet-4.5, gpt-4o-mini)
LLM_MODEL=gemini-3.1-flash-lite-preview
# API key for the selected provider
LLM_API_KEY=your-api-key-here

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Rate Limiting Configuration
LLM_MAX_CONCURRENCY=5
LLM_MAX_RETRIES=5
LLM_RETRY_MIN_WAIT=1.0
LLM_RETRY_MAX_WAIT=60.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Localization / Internationalization
# Select a country preset: ID (Indonesia), US (United States), IN (India), PH (Philippines)
# This sets currency, admin levels, default prices, etc.
LOCALE_COUNTRY=ID

# Override specific locale settings (optional)
# LOCALE_CURRENCY_CODE=USD
# LOCALE_CURRENCY_SYMBOL=$
